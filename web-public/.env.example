# Firebase Admin SDK (ビルド時に Firestore からデータ取得)
# Cloud Run Jobs や Cloud Build 環境では自動的に認証される
# ローカルでは Application Default Credentials を使用

# Google Cloud Project
GOOGLE_CLOUD_PROJECT=ghostinthearchive

# Firebase Emulator (ローカル開発用)
FIRESTORE_EMULATOR_HOST=localhost:8080

# Google Tag Manager (本番環境のみ - Cloud Build で設定)
# ローカル開発では省略（GTM は読み込まれない）
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
