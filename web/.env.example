# Firebase Configuration
# Firebaseコンソールから取得した設定値を入力してください
# https://console.firebase.google.com/

# クライアント側SDK用
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# サーバー側Admin SDK用（サービスアカウントキーのパス）
# FirebaseコンソールからJSONキーをダウンロードして配置
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# ISR再検証用シークレット
REVALIDATE_SECRET=your-revalidate-secret-token

# 開発環境設定
# Firebase Emulator使用時はtrueに設定
USE_FIREBASE_EMULATOR=false
FIREBASE_EMULATOR_HOST=localhost
FIRESTORE_EMULATOR_PORT=8080

# ========================================
# 認証設定（ローカル開発用）
# ========================================

# Google OAuth クライアント
# Google Cloud Console → APIs & Services → Credentials で作成
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# NextAuth.js
# NEXTAUTH_SECRET: `openssl rand -base64 32` で生成
NEXTAUTH_SECRET=your-random-32-character-secret
NEXTAUTH_URL=http://localhost:3000
