# Ghost in the Archive - Environment Variables

# NARA Catalog API Key
# Request from: Catalog_API@nara.gov
# Limit: 10,000 requests/month
NARA_API_KEY=your_api_key_here

# Google Cloud Project (for Vertex AI / ADK)
GOOGLE_CLOUD_PROJECT=your_project_id

# Optional: Google Cloud Region
GOOGLE_CLOUD_REGION=us-central1
