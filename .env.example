# Ghost in the Archive - Environment Variables
# Python バックエンド（mystery_agents / podcast_agents / services）用

# === Google Cloud ===
# Vertex AI / ADK で使用するプロジェクト ID
GOOGLE_CLOUD_PROJECT=your_project_id
# Vertex AI リージョン（例: asia-northeast1）
GOOGLE_CLOUD_LOCATION=your_region
# Vertex AI バックエンド使用（TRUE を設定）
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# === OpenRouter API（Storyteller ストーリーテラー選択用）===
# OpenRouter API キー（Claude / GPT / Llama / DeepSeek / Mistral を一元管理）
OPENROUTER_API_KEY=your_openrouter_api_key

# === Archive API Keys ===
# Digital Public Library of America（https://dp.la/developers で取得）
DPLA_API_KEY=your_dpla_api_key
# Deutsche Digitale Bibliothek API キー
DDB_API_KEY=your_ddb_api_key
# Europeana API キー
EUROPEANA_API_KEY=your_europeana_api_key
# Trove API キー（National Library of Australia、https://trove.nla.gov.au/about/create-something/using-api で取得）
TROVE_API_KEY=your_trove_api_key
# NYPL Digital Collections API トークン（https://api.repo.nypl.org/ で取得）
NYPL_API_TOKEN=your_nypl_api_token
# OpenAlex Academic Search API Key (free)
OPENALEX_API_KEY=your_openalex_api_key

# === Firebase Emulator（ローカル開発用）===
# Firestore エミュレータ（例: localhost:8080）
FIRESTORE_EMULATOR_HOST=localhost:8080
# Storage エミュレータ（例: localhost:9199）
STORAGE_EMULATOR_HOST=localhost:9199

# === Cloud Run ===
# サービスポート（例: 8080）
# PORT=8080

# === Feature Flags ===
# Librarian のリンク検証（true / false）
# ENABLE_LINK_VALIDATION=true
