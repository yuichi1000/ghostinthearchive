# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ghostinthearchive.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ghostinthearchive
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=ghostinthearchive.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:demo

# Firebase Emulator (ローカル開発用)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=localhost
NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
NEXT_PUBLIC_STORAGE_EMULATOR_PORT=9199

# Google Cloud Project
GOOGLE_CLOUD_PROJECT=ghostinthearchive
GOOGLE_CLOUD_REGION=asia-northeast1

# Curator Service URL（テーマ提案 API）
CURATOR_SERVICE_URL=http://localhost:8001

# 公開サイト URL（記事公開後のリダイレクト用）
PUBLIC_SITE_URL=https://ghostinthearchive.ai
