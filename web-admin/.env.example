# web-admin - Environment Variables

# === Firebase Client SDK ===
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# === Google OAuth ===
# 本番では Cloud Run シークレットで管理（.env.production に含まない）
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# === NextAuth.js ===
# 本番では Cloud Run シークレット / 環境変数で管理（.env.production に含まない）
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3001

# === Firebase Emulator（ローカル開発専用 - 本番不要）===
# クライアント側
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_EMULATOR_HOST=localhost
NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
NEXT_PUBLIC_STORAGE_EMULATOR_PORT=9199

# === Firebase Admin SDK Emulator（ローカル開発専用 - 本番不要）===
# サーバーサイド Emulator 使用（true / false）
USE_FIREBASE_EMULATOR=true
FIREBASE_EMULATOR_HOST=localhost
FIRESTORE_EMULATOR_PORT=8080

# === Google Cloud ===
# 本番では Cloud Run で自動設定（.env.production に含まない）
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_REGION=your_region

# === Backend Service URLs ===
# 本番では Cloud Run 環境変数で管理（.env.production に含まない）
# パイプライン API（例: http://localhost:8002）
PIPELINE_SERVICE_URL=your_pipeline_service_url
# テーマ提案 API（例: http://localhost:8001）
CURATOR_SERVICE_URL=your_curator_service_url

# === Cloud Build ===
# 本番では Cloud Run 環境変数で管理（.env.production に含まない）
# web-public 再ビルド用トリガー ID
CLOUD_BUILD_TRIGGER_ID=your_trigger_id

# === Public Site ===
# 公開サイト URL（記事公開後のリダイレクト用。例: https://ghostinthearchive.ai）
NEXT_PUBLIC_SITE_URL=your_site_url
